    {
      "registryType": "npm",
      "identifier": "claracars-mcp",
      "version": "0.1.1",
      "transport": { "type": "stdio" }
    }
  ],
  "remotes": [
    {
      "type": "streamable-http",
      "url": "https://claracars.pt/mcp"
    }
  ]
}
